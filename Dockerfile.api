# Dockerfile.api

FROM download-car-base:latest

WORKDIR /download-car

COPY app.py /download-car/

# Instalar dependências adicionais necessárias para a API
RUN pip install fastapi uvicorn httpx Pillow tqdm python-multipart geopandas fiona

ENTRYPOINT ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]

