# .config.env
# =============================================================================
# ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE - download-car
# =============================================================================
# Este arquivo contém variáveis de ambiente de exemplo para configuração.
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# 
# IMPORTANTE: Este arquivo pode ser versionado no repositório pois não contém
# informações sensíveis. Para produção, use um arquivo .env separado.

# =============================================================================
# CONFIGURAÇÃO DOCKER - Imagem Base
# =============================================================================
# Controla qual imagem base usar (dev/pro)
# Valores possíveis: download-car-dev:latest, download-car-pro:latest
BASE_IMAGE=download-car-dev:latest

# =============================================================================
# VARIÁVEIS DE DOWNLOAD
# =============================================================================
# Estado para download (ex: SP, PA, MG, etc.)
STATE=SP

# Tipo de polígono para download
# Valores possíveis: APPS, AREA_PROPERTY, AREA_RURAL, AREA_URBANA, etc.
POLYGON=AREA_PROPERTY

# Pasta para armazenamento dos arquivos baixados
FOLDER=temp/SP

# Número máximo de tentativas para download
TRIES=25

# Ativa modo debug (true/false)
DEBUG=false

# Timeout em segundos para cada tentativa de download
TIMEOUT=30

# Número máximo de tentativas para download de cada arquivo
MAX_RETRIES=5

# =============================================================================
# VARIÁVEIS DA API
# =============================================================================
# URL base da API
API_URL=http://192.168.5.179:8787

# Origens permitidas para CORS (separadas por vírgula)
CORS_ALLOW_ORIGINS=*

# Permite credenciais em requisições CORS (true/false)
CORS_ALLOW_CREDENTIALS=true

# Métodos HTTP permitidos para CORS
CORS_ALLOW_METHODS=GET,POST,OPTIONS

# Headers permitidos para CORS
CORS_ALLOW_HEADERS=*

# =============================================================================
# VARIÁVEIS DE PROPRIEDADES
# =============================================================================
# Pasta para armazenamento de arquivos de propriedades
PROPERTY_FOLDER=PROPERTY

# Número máximo de tentativas para download de propriedades
PROPERTY_TRIES=25

# Ativa modo debug para downloads de propriedades (true/false)
PROPERTY_DEBUG=false

# Timeout em segundos para downloads de propriedades
PROPERTY_TIMEOUT=30

# Número máximo de tentativas para cada propriedade
PROPERTY_MAX_RETRIES=5

# =============================================================================
# VARIÁVEIS DO BRASIL (RECLASSIFICAÇÃO E IBGE)
# =============================================================================
# Link padrão do MapBiomas para download
MAPBIOMAS_URL=https://storage.googleapis.com/mapbiomas-public/initiative/collection-7/brasil/coverage/mapbiomas-brasil-coverage-2022.tif

# URL padrão para dados do IBGE
IBGE_URL=https://geoftp.ibge.gov.br/organizacao_do_territorio/malhas_territoriais/malhas_municipais/municipio_2022/Brasil/BR/BR_Municipios_2022.zip

# =============================================================================
# VARIÁVEIS DO FRONTEND (NGINX)
# =============================================================================
# URL do endpoint da API para o frontend
API_ENDPOINT_URL=http://192.168.5.179:8787

# Polígono padrão selecionado no frontend
DEFAULT_POLYGON=AREA_PROPERTY

# Timeout padrão em milissegundos
DEFAULT_TIMEOUT=800000

# Incremento do timeout em milissegundos
TIMEOUT_INCREMENT=10000

# Timeout mínimo em milissegundos
MIN_TIMEOUT=10000

# Timeout máximo em milissegundos
MAX_TIMEOUT=300000

# Timeout de rede em milissegundos
NETWORK_TIMEOUT=30000

# Configurações da API para o nginx
API_HOST=192.168.5.179
API_PORT=8787
API_PATH=/

# =============================================================================
# TIMEOUTS ESPECÍFICOS POR ESTADO (em milissegundos)
# =============================================================================
# Timeouts específicos por estado
STATE_TIMEOUT_AC=60000
STATE_TIMEOUT_AL=120000
STATE_TIMEOUT_AM=60000
STATE_TIMEOUT_AP=60000
STATE_TIMEOUT_BA=120000
STATE_TIMEOUT_CE=120000
STATE_TIMEOUT_DF=60000
STATE_TIMEOUT_ES=120000
STATE_TIMEOUT_GO=120000
STATE_TIMEOUT_MA=120000
STATE_TIMEOUT_MG=180000
STATE_TIMEOUT_MS=120000
STATE_TIMEOUT_MT=120000
STATE_TIMEOUT_PA=120000
STATE_TIMEOUT_PB=120000
STATE_TIMEOUT_PE=120000
STATE_TIMEOUT_PI=120000
STATE_TIMEOUT_PR=180000
STATE_TIMEOUT_RJ=180000
STATE_TIMEOUT_RN=120000
STATE_TIMEOUT_RO=120000
STATE_TIMEOUT_RR=60000
STATE_TIMEOUT_RS=180000
STATE_TIMEOUT_SC=180000
STATE_TIMEOUT_SE=120000
STATE_TIMEOUT_SP=300000
STATE_TIMEOUT_TO=120000

# =============================================================================
# CONFIGURAÇÕES OCR (OPCIONAIS)
# =============================================================================
# Configuração do Tesseract OCR para reconhecimento de captcha
TESSERACT_CONFIG=--oem 3 --psm 8 -c tessedit_char_whitelist=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789

# Idioma para reconhecimento PaddleOCR
PADDLE_OCR_LANG=en

# Habilita uso de GPU para PaddleOCR (true/false)
PADDLE_OCR_USE_GPU=false

# Exibe logs do PaddleOCR (true/false)
PADDLE_OCR_SHOW_LOG=false

# =============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS POSTGIS
# =============================================================================
# Host do banco de dados PostgreSQL/PostGIS
DB_HOST=localhost

# Porta do banco de dados PostgreSQL/PostGIS
DB_PORT=5432

# Nome do banco de dados
DB_NAME=download_car

# Usuário do banco de dados
DB_USER=postgres

# Senha do banco de dados
DB_PASSWORD=postgres

# Schema do banco de dados (opcional, padrão: public)
DB_SCHEMA=public

# Pool de conexões (opcional, padrão: 5)
DB_POOL_SIZE=5

# Timeout de conexão em segundos (opcional, padrão: 30)
DB_TIMEOUT=30

# =============================================================================
# CONFIGURAÇÕES DO SISTEMA (OPCIONAIS)
# =============================================================================
# Habilita pré-carregamento dos modelos do PaddleOCR durante build (1/0)
PRELOAD_MODELS=0

# Configuração do Docker para builds
DOCKER_CONFIG=/tmp/docker-config-noauth

# Versão do Python utilizada no container
PYTHON_VERSION=3.11.9

# =============================================================================
# INSTRUÇÕES DE USO
# =============================================================================
# 1. Copie este arquivo para .env:
#    cp .config.env .env
#
# 2. Ajuste os valores conforme necessário
#
# 3. Para desenvolvimento:
#    BASE_IMAGE=download-car-dev:latest docker compose up
#
# 4. Para produção:
#    BASE_IMAGE=download-car-pro:latest docker compose up
#    ou simplesmente: docker compose up (usa o padrão)
#
# 5. Para usar com Makefile:
#    make build-dev    # Build de desenvolvimento
#    make build-pro    # Build de produção
#
# 6. Para carregar variáveis deste arquivo:
#    export $(cat .config.env | grep -v '^#' | xargs)
# ============================================================================= 