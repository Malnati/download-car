# Dockerfile.dev
FROM download-car-base:latest

# Instalar ferramentas de debug e desenvolvimento
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl wget ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Instalar Poetry
RUN pip install poetry

# Configurar Poetry para não criar ambiente virtual (já estamos no container)
RUN poetry config virtualenvs.create false

WORKDIR /download-car

# Copiar dependências do projeto
COPY pyproject.toml ./
COPY poetry.lock* ./
COPY LICENSE ./

# Copiar o restante do projeto ANTES da instalação das dependências
COPY . .

# Instalar todas as dependências (incluindo dev)
RUN poetry install --extras dev

# Instalar PaddleOCR (opcional, caso queira manter dependências opcionais)
RUN poetry run pip install paddlepaddle paddleocr
