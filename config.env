# Configuração da API - Download CAR
# Arquivo de configuração de ambiente

# URL do endpoint da API (via proxy nginx)
API_ENDPOINT_URL=http://192.168.5.179:8787/api

# Configurações de timeout (em milissegundos)
DEFAULT_TIMEOUT=30000
TIMEOUT_INCREMENT=10000
MIN_TIMEOUT=10000
MAX_TIMEOUT=300000

# Configurações do servidor
API_HOST=192.168.5.179
API_PORT=8000
API_PATH=/download_state

# Configurações de rede
NETWORK_TIMEOUT=30
MAX_RETRIES=5

# Configurações CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=* 